<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">

  <title>
    {%- if page_title -%}
      {{ page_title }} — {{ shop.name }}
    {%- else -%}
      {{ shop.name }} — Fresh Groceries Delivered Weekly
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- else -%}
    <meta name="description" content="Reliable grocery subscriptions, thoughtfully built for everyday tables. Curated hauls delivered on your schedule.">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Feather Icons (lightweight alternative to Lucide) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.css">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  {%- if request.page_type == 'index' -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "{{ shop.name }}",
        "url": "{{ shop.url }}"
      }
    </script>
  {%- endif -%}
</head>

<body class="template-{{ request.page_type }}{% if request.page_type == 'index' %} page-home{% endif %}">
  <a class="skip-to-content" href="#main-content">Skip to content</a>

  {% section 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Feather Icons Init -->
  <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof feather !== 'undefined') {
        feather.replace();
      }
    });
  </script>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
